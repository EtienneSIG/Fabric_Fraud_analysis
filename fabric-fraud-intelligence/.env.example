# Fabric Fraud Intelligence — environment configuration
# Rayfin injects VITE_* variables at build/deploy time. For local dev copy this
# file to .env.local and adjust. All values are optional in mock mode.

# App mode: "mock" (deterministic demo data) or "fabric" (live Fabric Data Agent)
VITE_FABRIC_APP_MODE=mock

# Microsoft Fabric identifiers (used when VITE_FABRIC_APP_MODE=fabric)
VITE_FABRIC_WORKSPACE_ID=
VITE_FABRIC_DATA_AGENT_ID=
VITE_FABRIC_TENANT_ID=

# Rayfin runtime (populated automatically by `rayfin up` / `rayfin env`)
# VITE_RAYFIN_API_URL=
# VITE_RAYFIN_PUBLISHABLE_KEY=
# VITE_FABRIC_ITEM_ID=
# VITE_FABRIC_PORTAL_URL=
